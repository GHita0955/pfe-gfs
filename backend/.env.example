# Backend environment example (MySQL)
# Copy this file to .env and adjust values.

SECRET_KEY=pfe-secret-key-change-in-production
JWT_SECRET_KEY=jwt-pfe-secret-change-in-production

# Option A: full SQLAlchemy URI
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/reservsmart

# Option B: compose URI from MYSQL_* vars
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=reservsmart
